# KoopCare Fullstack Demo Platform
# Copy this file to .env for local development.

APP_ENV=development
APP_NAME=KoopCare Fullstack Demo Platform

# Planned local ports.
WEB_PORT=5174
API_PORT=5002
# Public platforms such as Railway provide PORT automatically.
# Runtime code prefers PORT first, then API_PORT, then 5002.
PORT=
DB_PORT=3308
VITE_API_BASE_URL=http://localhost:5002

# Public single-service preview/deployment.
# In local dev, the React app and API run on separate ports.
# In public mode, the API can serve the built React app from apps/web/dist.
SERVE_WEB_APP=false
WEB_DIST_PATH=

# Planned database connection.
DB_HOST=127.0.0.1
DB_USER=koopcare_demo_user
DB_PASSWORD=koopcare_demo_password
DB_NAME=koopcare_demo_db

# Existing MLOps API from project 13.
ML_API_BASE_URL=http://127.0.0.1:8000
ML_API_TIMEOUT_MS=5000
ML_STATUS_TIMEOUT_MS=1500
# Use optional_fallback for local demo without Python service.
# Use strict_ml for production-like demos so fake fallback scores are not created.
ML_SCORING_MODE=optional_fallback

# Optional local JSON storage path for the MVP API.
# Leave empty to use apps/api/.data/applications.local.json.
DATA_FILE_PATH=

# Authentication placeholders for future progress.
JWT_SECRET=change_this_in_real_development
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
